rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users 컬렉션: 인증된 유저 전체 읽기 허용 (소셜 랭킹, Day1 피드, 던전 글로벌 싱크에 필요)
    // 쓰기는 본인 문서만 가능
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // push_logs: 관리자만 읽기/쓰기 (Cloud Functions에서 서버사이드 쓰기)
    match /push_logs/{logId} {
      allow read: if request.auth != null && request.auth.token.email == 'nazi2k@gmail.com';
      allow write: if false; // Cloud Functions (Admin SDK)에서만 쓰기
    }

    // push_feedback: 인증된 유저 쓰기, 관리자만 읽기
    match /push_feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.email == 'nazi2k@gmail.com';
      allow update, delete: if false;
    }

    // reels_reactions: 인증된 유저 읽기/쓰기
    match /reels_reactions/{postId} {
      allow read, write: if request.auth != null;
    }
  }
}
