rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // 헬퍼 함수
    // ──────────────────────────────────────────────

    // 관리자 또는 운영자 권한 확인 (admin 또는 adminOperator claim)
    function isAdminOrOperator() {
      return request.auth.token.admin == true || request.auth.token.adminOperator == true;
    }

    // stats 맵 검증 (str, int, cha, vit, wlth, agi — 모두 number >= 0, 최대 9999)
    function isValidStatsMap(s) {
      return s is map
        && s.keys().hasOnly(['str', 'int', 'cha', 'vit', 'wlth', 'agi'])
        && (!('str' in s) || (s.str is number && s.str >= 0 && s.str <= 9999))
        && (!('int' in s) || (s.int is number && s.int >= 0 && s.int <= 9999))
        && (!('cha' in s) || (s.cha is number && s.cha >= 0 && s.cha <= 9999))
        && (!('vit' in s) || (s.vit is number && s.vit >= 0 && s.vit <= 9999))
        && (!('wlth' in s) || (s.wlth is number && s.wlth >= 0 && s.wlth <= 9999))
        && (!('agi' in s) || (s.agi is number && s.agi >= 0 && s.agi <= 9999));
    }

    // 포인트 급증 방지: 1회 update 시 최대 50,000 포인트 증가 허용
    function isValidPointsDelta() {
      let before = resource.data;
      let after = request.resource.data;
      return !('points' in after)
        || !('points' in before)
        || (after.points - before.points <= 50000);
    }

    // 레벨 급상승 방지: 1회 update 시 최대 1 레벨 증가 허용
    function isValidLevelDelta() {
      let before = resource.data;
      let after = request.resource.data;
      return !('level' in after)
        || !('level' in before)
        || (after.level - before.level <= 1);
    }

    // streak 맵 검증
    function isValidStreakMap(s) {
      return s is map
        && s.keys().hasOnly(['currentStreak', 'lastActiveDate', 'multiplier'])
        && (!('currentStreak' in s) || (s.currentStreak is number && s.currentStreak >= 0))
        && (!('multiplier' in s) || (s.multiplier is number && s.multiplier >= 0))
        && (!('lastActiveDate' in s) || s.lastActiveDate == null || s.lastActiveDate is string);
    }

    // stepData 맵 검증
    function isValidStepData(s) {
      return s is map
        && s.keys().hasOnly(['date', 'rewardedSteps', 'totalSteps'])
        && (!('date' in s) || s.date is string)
        && (!('rewardedSteps' in s) || (s.rewardedSteps is number && s.rewardedSteps >= 0))
        && (!('totalSteps' in s) || (s.totalSteps is number && s.totalSteps >= 0));
    }

    // ──────────────────────────────────────────────
    // users 문서 필드 타입 검증
    // ──────────────────────────────────────────────
    // 참고: areWrittenFieldsAllowed() (diff().affectedKeys().hasOnly()) 검증은
    // Firestore 표현식 한도(1000/요청)를 초과하여 제거함.
    // 개별 필드 타입 검증으로 허용되지 않은 값 쓰기를 방어함.
    // 검증을 두 함수로 분리하여 표현식 수를 분산.

    // Part 1: 핵심 필드 + 맵 + 배열 + 불리언 + 짧은 문자열/숫자
    function isValidUserFieldsPart1() {
      let d = request.resource.data;
      return
        // ── 핵심 필드 ──
        (!('name' in d) || (d.name is string && d.name.size() >= 1 && d.name.size() <= 30))
        && (!('level' in d) || (d.level is number && d.level >= 1 && d.level <= 999))
        && (!('points' in d) || (d.points is number && d.points >= 0))
        && (!('photoURL' in d) || d.photoURL == null || (d.photoURL is string && d.photoURL.size() <= 1024))
        // ── 맵 필드 ──
        && (!('stats' in d) || isValidStatsMap(d.stats))
        && (!('pendingStats' in d) || isValidStatsMap(d.pendingStats))
        && (!('streak' in d) || isValidStreakMap(d.streak))
        && (!('stepData' in d) || isValidStepData(d.stepData))
        // ── 배열 필드 ──
        && (!('friends' in d) || (d.friends is list && d.friends.size() <= 500))
        // ── 불리언 필드 ──
        && (!('syncEnabled' in d) || d.syncEnabled is bool)
        && (!('gpsEnabled' in d) || d.gpsEnabled is bool)
        && (!('pushEnabled' in d) || d.pushEnabled is bool)
        && (!('hasActiveReels' in d) || d.hasActiveReels is bool)
        && (!('_profileUploadFailed' in d) || d._profileUploadFailed is bool)
        && (!('privateAccount' in d) || d.privateAccount is bool)
        // ── 짧은 문자열/숫자 필드 ──
        && (!('instaId' in d) || d.instaId == null || (d.instaId is string && d.instaId.size() <= 30))
        && (!('linkedinId' in d) || d.linkedinId == null || (d.linkedinId is string && d.linkedinId.size() <= 100))
        && (!('fcmToken' in d) || d.fcmToken == null || (d.fcmToken is string && d.fcmToken.size() <= 500))
        && (!('questWeekStart' in d) || d.questWeekStart == null || (d.questWeekStart is string && d.questWeekStart.size() <= 10))
        && (!('lastRouletteDate' in d) || d.lastRouletteDate == null || (d.lastRouletteDate is string && d.lastRouletteDate.size() <= 10))
        && (!('nameLastChanged' in d) || d.nameLastChanged == null || d.nameLastChanged is number)
        && (!('lastReelsPostTs' in d) || d.lastReelsPostTs == null || d.lastReelsPostTs is number);
    }

    // Part 2: JSON 직렬화 문자열 필드 (타입만 검증, 크기는 클라이언트에서 검증)
    function isValidUserFieldsPart2() {
      let d = request.resource.data;
      return
        (!('questStr' in d) || d.questStr == null || d.questStr is string)
        && (!('diaryStr' in d) || d.diaryStr == null || d.diaryStr is string)
        && (!('reelsStr' in d) || d.reelsStr == null || d.reelsStr is string)
        && (!('dungeonStr' in d) || d.dungeonStr == null || d.dungeonStr is string)
        && (!('diyQuestsStr' in d) || d.diyQuestsStr == null || d.diyQuestsStr is string)
        && (!('questHistoryStr' in d) || d.questHistoryStr == null || d.questHistoryStr is string)
        && (!('titleHistoryStr' in d) || d.titleHistoryStr == null || d.titleHistoryStr is string)
        && (!('streakStr' in d) || d.streakStr == null || d.streakStr is string)
        && (!('rareTitleStr' in d) || d.rareTitleStr == null || d.rareTitleStr is string)
        && (!('ddaysStr' in d) || d.ddaysStr == null || d.ddaysStr is string)
        && (!('ddayCaption' in d) || d.ddayCaption == null || d.ddayCaption is string)
        && (!('lastBonusExpDate' in d) || d.lastBonusExpDate == null || d.lastBonusExpDate is string)
        && (!('lifeStatusStr' in d) || d.lifeStatusStr == null || d.lifeStatusStr is string)
        && (!('libraryStr' in d) || d.libraryStr == null || d.libraryStr is string)
        && (!('moviesStr' in d) || d.moviesStr == null || d.moviesStr is string)
        && (!('runningCalcHistoryStr' in d) || d.runningCalcHistoryStr == null || d.runningCalcHistoryStr is string)
        && (!('ormCalcHistoryStr' in d) || d.ormCalcHistoryStr == null || d.ormCalcHistoryStr is string)
        && (!('futureNetworthStr' in d) || d.futureNetworthStr == null || d.futureNetworthStr is string);
    }

    // ──────────────────────────────────────────────
    // users 컬렉션
    // ──────────────────────────────────────────────
    // 인증된 유저 전체 읽기 허용 (소셜 랭킹, Day1 피드, 던전 글로벌 싱크에 필요)
    // 쓰기는 본인 문서만 + 핵심 필드 타입 검증 통과 시
    // 참고: JSON 직렬화 문자열 필드(questStr, diaryStr 등)는 Firestore 규칙
    // 표현식 한도로 인해 서버 검증 생략, 클라이언트에서 검증 (app.js _strLimits)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && isValidUserFieldsPart1();
      // update 시 타입 검증 + 델타 검증 (포인트·레벨 급변 방지)
      allow update: if request.auth != null
        && request.auth.uid == userId
        && isValidUserFieldsPart1()
        && isValidPointsDelta()
        && isValidLevelDelta();
      // 계정 삭제: 본인 문서만 삭제 가능 (Google 정책 준수)
      allow delete: if request.auth != null
        && request.auth.uid == userId;

      // 알림 이력: 본인만 읽기 가능, 쓰기는 Cloud Functions 전용
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // ──────────────────────────────────────────────
    // usernames: 닉네임 유일성 보장 (usernames/{normalizedName})
    // 문서 ID = 소문자 정규화된 닉네임, 데이터 = { uid, name, claimedAt }
    // ──────────────────────────────────────────────
    match /usernames/{nameId} {
      allow read: if request.auth != null;
      // 생성: 인증된 유저, 본인 uid만 기록 가능
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid', 'name', 'claimedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 30
        && request.resource.data.claimedAt is number;
      // 수정: 기존 소유자만 가능 (닉네임 이전 시)
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      // 삭제: 기존 소유자만 가능 (닉네임 변경 시 이전 닉네임 해제)
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ──────────────────────────────────────────────
    // push_logs: 관리자만 읽기 (Cloud Functions Admin SDK에서만 쓰기)
    // ──────────────────────────────────────────────
    match /push_logs/{logId} {
      allow read: if request.auth != null && isAdminOrOperator();
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // push_feedback: 인증된 유저 생성, 관리자만 읽기
    // ──────────────────────────────────────────────
    match /push_feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['device', 'os', 'received', 'type', 'memo', 'timestamp', 'reporter'])
        && request.resource.data.device is string
        && request.resource.data.os is string
        && request.resource.data.received is string
        && request.resource.data.type is string
        && request.resource.data.memo is string
        && request.resource.data.memo.size() <= 2000
        && request.resource.data.reporter is string;
      allow read: if request.auth != null && isAdminOrOperator();
      allow update, delete: if false;
    }

    // ──────────────────────────────────────────────
    // reels_reactions: 인증된 유저 읽기/쓰기 + 구조 검증
    // ──────────────────────────────────────────────
    match /reels_reactions/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['likes', 'comments'])
        && request.resource.data.likes is list
        && request.resource.data.likes.size() <= 1000
        && request.resource.data.comments is list
        && request.resource.data.comments.size() <= 500;
    }

    // ──────────────────────────────────────────────
    // post_reports: 인증 유저 읽기/생성, 관리자 전체 쓰기
    // ──────────────────────────────────────────────
    match /post_reports/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['postId', 'reporters', 'reportCount', 'lastReportedAt'])
        && request.resource.data.postId is string
        && request.resource.data.reporters is list
        && request.resource.data.reporters.size() <= 100
        && request.resource.data.reportCount is number
        && request.resource.data.lastReportedAt is number;
    }

    // ──────────────────────────────────────────────
    // app_config: 인증된 유저 읽기, 관리자만 쓰기
    // ──────────────────────────────────────────────
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdminOrOperator();
    }

    // ──────────────────────────────────────────────
    // announcements: 인증된 유저 읽기, Cloud Functions Admin SDK에서만 쓰기
    // ──────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // user_backups: 관리자만 읽기 (Cloud Functions Admin SDK에서만 쓰기)
    // ──────────────────────────────────────────────
    match /user_backups/{backupId} {
      allow read: if request.auth != null && isAdminOrOperator();
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // screening_results: 자동 스크리닝 결과 (관리자만 읽기, Cloud Functions에서 쓰기)
    // ──────────────────────────────────────────────
    match /screening_results/{resultId} {
      allow read: if request.auth != null && isAdminOrOperator();
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // screening_config: 자동 스크리닝 설정 (관리자만 읽기/쓰기 via Cloud Functions)
    // ──────────────────────────────────────────────
    match /screening_config/{docId} {
      allow read: if request.auth != null && isAdminOrOperator();
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // app_error_logs: 인증 유저가 본인 에러 로그만 생성 (디버깅용)
    // ──────────────────────────────────────────────
    match /app_error_logs/{logId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid', 'category', 'message', 'detail', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 40
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 500
        && request.resource.data.detail is string
        && request.resource.data.detail.size() <= 2000
        && request.resource.data.createdAt is number;
      allow read, update, delete: if request.auth != null && isAdminOrOperator();
    }
  }
}
