{
  "ci": {
    "collect": {
      "staticDistDir": "./www",
      "url": ["http://localhost/app.html"],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.40 }],
        "categories:accessibility": ["warn", { "minScore": 0.70 }],
        "categories:best-practices": ["warn", { "minScore": 0.70 }],
        "categories:seo": ["warn", { "minScore": 0.70 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 5000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 12000 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.25 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 1500 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
