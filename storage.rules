rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // profile_images: 공개 읽기 (CDN 캐싱 활성화), 본인만 쓰기/삭제
    match /profile_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId
                            && request.resource.size < 500 * 1024
                            && request.resource.contentType.matches('image/(jpeg|png|webp|gif|heic|heif)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // planner_photos: 본인만 쓰기/삭제, 인증된 유저 읽기
    match /planner_photos/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId
                            && request.resource.size < 2 * 1024 * 1024
                            && request.resource.contentType.matches('image/(jpeg|png|webp|gif|heic|heif)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // reels_photos: 공개 읽기 (CDN 캐싱 활성화), 본인만 쓰기/삭제
    match /reels_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId
                            && request.resource.size < 2 * 1024 * 1024
                            && request.resource.contentType.matches('image/(jpeg|png|webp|gif|heic|heif)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // thumbs/: Cloud Function이 생성하는 썸네일 (읽기 전용, 쓰기는 Admin SDK)
    match /thumbs/reels_photos/{allPaths=**} {
      allow read: if true;
    }
    match /thumbs/profile_images/{allPaths=**} {
      allow read: if true;
    }
    match /thumbs/planner_photos/{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
