{
  "name": "levelup-reboot",
  "version": "1.0.304",
  "description": "LEVEL UP: REBOOT - 게임처럼 현실을 레벨업하는 앱",
  "license": "UNLICENSED",
  "main": "www/app.html",
  "scripts": {
    "sync": "cap sync android",
    "add-android": "cap add android",
    "build-apk": "cd android && chmod +x ./gradlew && ./gradlew assembleDebug",
    "generate-config": "bash scripts/generate-firebase-config.sh",
    "version-bump": "bash scripts/version-bump.sh",
    "version-sync": "bash scripts/version-bump.sh",
    "backup": "bash scripts/backup.sh",
    "backup:zip": "bash scripts/backup.sh --zip",
    "backup:full": "bash scripts/backup.sh --full",
    "backup:git": "bash scripts/github-backup.sh",
    "backup:bundle": "bash scripts/github-backup.sh --bundle",
    "backup:cros": "bash scripts/cros-package.sh"
  },
  "dependencies": {
    "@capacitor-community/admob": "^6.2.0",
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/local-notifications": "^6.0.1",
    "@capacitor/push-notifications": "^6.0.2",
    "@codetrix-studio/capacitor-google-auth": "3.4.0-rc.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
